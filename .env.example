# .env.example — Trade-CLI configuração completa
# Copiar para .env e preencher os valores reais
# NUNCA commitar o .env com valores reais

# ── MT5 (MetaTrader 5) ─────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── LLM Backend (Ollama — padrão local) ───────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:7b
# Timeout em segundos para chamadas ao LLM
LLM_TIMEOUT_SECONDS=120

# ── LLM Fallback (OpenAI-compatible, OPCIONAL) ─────────
# Deixar vazio para usar apenas Ollama (recomendado)
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# ── Base de Dados ──────────────────────────────────────
DB_PATH=database.db

# ── Obsidian Vault ─────────────────────────────────────
OBSIDIAN_VAULT_PATH=./Trade-CLI-Vault

# ── Sistema ────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=trade-cli.log
MOCK_DATA=true
