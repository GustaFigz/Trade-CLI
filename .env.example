# ════════════════════════════════════════════════
# Trade-CLI — Environment Configuration
# Copiar para .env e preencher com valores reais
# NUNCA commitar o .env
# ════════════════════════════════════════════════

# ─── LLM Backend (Ollama — padrão local) ────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest
# Alternativas: llama3.1:8b, mistral:7b, phi3:mini
LLM_TIMEOUT_SECONDS=120

# ─── LLM Fallback OpenAI-compatible (OPCIONAL — deixar vazio) 
# Funciona com qualquer API OpenAI-compatible (LM Studio, etc.)
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# ─── MT5 (MetaTrader 5 — Phase 2.3+) ────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ─── Base de Dados ───────────────────────────────────────────
DB_PATH=database.db

# ─── Obsidian Vault ──────────────────────────────────────────
OBSIDIAN_VAULT_PATH=./Trade-CLI-Vault

# ─── Modo de Dados ───────────────────────────────────────────
# true = usar dados mock; false = tentar MT5 real
MOCK_DATA=true

# ─── Sistema ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=trade-cli.log
TRADECLI_VERSION=0.2.0
