# Trade-CLI Configuration
# Copy this to .env and fill in your credentials
# Phase 1: Leave most empty (will be used in Phase 2+)

# MT5 Integration (Phase 2)
# MT5_LOGIN=12345678
# MT5_PASSWORD=your_password
# MT5_SERVER=ICMarketsSC-Demo

# TradingView Integration (Phase 2)
# TRADINGVIEW_SESSION_ID=your_session_id
# TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret

# Local Gemma Model (Phase 2)
# GEMMA_MODEL_PATH=/path/to/gemma-7b-model
# GEMMA_DEVICE=cuda  # or cpu

# Database
DATABASE_PATH=database.db

# Obsidian Vault
OBSIDIAN_VAULT_PATH=Trade-CLI-Vault

# FTMO Account Details (for reference, not stored as secret)
FTMO_BALANCE=100000
FTMO_ACCOUNT_ID=your_account_id

# Logging
LOG_LEVEL=INFO
LOG_FILE=trade-cli.log

# Development
DEBUG=false
TEST_MODE=false
